{
  "version": 2,
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": "www",
  "functions": {
    "api/**/*.js": {
      "runtime": "node@20.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}